  avg(IF(event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed'), properties.retries, NULL)) AS avg_retries,
  avg(IF(event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed'), toFloat(properties.files_changed), NULL)) AS avg_files_changed,
  avg(IF(event = 'shipwright_ci_result', toFloat(properties.fix_attempts), NULL)) AS avg_fix_attempts,
  avgIf(dateDiff('hour', properties.started_at, properties.ts), event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed') AND dateDiff('hour', properties.started_at, properties.ts) > 0) AS avg_cycle_time_hours,
  avg(IF(event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed'), IF(toFloat(properties.estimated_h) > 0, toFloat(properties.actual_h) / toFloat(properties.estimated_h), NULL), NULL)) AS estimation_accuracy,
  avg(IF(event = 'shipwright_simplify_complete', toFloat(properties.dry), NULL)) AS simplify_avg_dry,
  avg(IF(event = 'shipwright_simplify_complete', toFloat(properties.dead_code), NULL)) AS simplify_avg_dead_code,
  avg(IF(event = 'shipwright_simplify_complete', toFloat(properties.naming), NULL)) AS simplify_avg_naming,
  avg(IF(event = 'shipwright_simplify_complete', toFloat(properties.complexity_fixes), NULL)) AS simplify_avg_complexity,
  avg(IF(event = 'shipwright_simplify_complete', toFloat(properties.consistency), NULL)) AS simplify_avg_consistency,
  avg(IF(event IN ('shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete'), toFloat(properties.findings), NULL)) AS avg_review_findings
FROM events
WHERE event IN ('shipwright_task_started', 'shipwright_task_blocked', 'shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete', 'shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed', 'shipwright_pr_created', 'shipwright_ci_result', 'shipwright_simplify_complete')
  AND timestamp >= toStartOfDay(now(), 'America/Los_Angeles') AND timestamp < toStartOfDay(now(), 'America/Los_Angeles') + interval 1 day
GROUP BY period
ORDER BY period ASC"
`;

exports[`buildFeaturesTasksQuery 7d preset produces interval filter 1`] = `
"SELECT
  extract(coalesce(toString(properties.task_id), toString(properties.task)), '^([A-Z]+)-') AS feature_prefix,
  count() AS tasks_completed,
  avg(properties.actual_h) AS avg_actual_h,
  avg(properties.estimated_h) AS avg_estimated_h
FROM events
WHERE event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed')
  AND match(coalesce(toString(properties.task_id), toString(properties.task)), '^[A-Z]+-[0-9]+\\\\.[0-9]+$')
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')
GROUP BY feature_prefix
ORDER BY tasks_completed DESC"
`;

exports[`buildFeaturesCiQuery 7d preset produces interval filter 1`] = `
"SELECT
  extract(coalesce(toString(properties.task_id), toString(properties.task)), '^([A-Z]+)-') AS feature_prefix,
  count() AS ci_total,
  countIf(toString(properties.passed_first_try) = 'true') AS ci_first_pass
FROM events
WHERE event = 'shipwright_ci_result'
  AND match(coalesce(toString(properties.task_id), toString(properties.task)), '^[A-Z]+-[0-9]+\\\\.[0-9]+$')
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')
GROUP BY feature_prefix"
`;

exports[`buildFeaturesReviewsQuery 7d preset produces interval filter 1`] = `
"SELECT
  extract(coalesce(toString(properties.task_id), toString(properties.task)), '^([A-Z]+)-') AS feature_prefix,
  count() AS reviews_total,
  countIf(properties.verdict = 'SHIP IT') AS reviews_ship_it
FROM events
WHERE event IN ('shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete')
  AND match(coalesce(toString(properties.task_id), toString(properties.task)), '^[A-Z]+-[0-9]+\\\\.[0-9]+$')
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')
GROUP BY feature_prefix"
`;

exports[`buildQueueFunnelQuery 7d preset produces interval filter 1`] = `
"SELECT
  countIf(event = 'shipwright_task_started') AS tasks_started,
  countIf(event IN ('shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete')) AS tasks_approved,
  countIf(event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed')) AS tasks_merged,
  countIf(event = 'shipwright_task_blocked') AS tasks_blocked,
  avg(IF(event IN ('shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete'), toFloat(properties.findings), NULL)) AS avg_review_findings
FROM events
WHERE event IN ('shipwright_task_started', 'shipwright_task_approved', 'shipwright_task_reviewed', 'shipwright_review_complete', 'shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed', 'shipwright_task_blocked')
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')"
`;

exports[`buildQueueCycleStartedQuery 7d preset produces interval filter 1`] = `
"SELECT
  coalesce(toString(properties.task_id), toString(properties.task)) AS task_id,
  timestamp
FROM events
WHERE event = 'shipwright_task_started'
  AND isNotNull(coalesce(toString(properties.task_id), toString(properties.task)))
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')"
`;

exports[`buildQueueCycleMergedQuery 7d preset produces interval filter 1`] = `
"SELECT
  coalesce(toString(properties.task_id), toString(properties.task)) AS task_id,
  timestamp
FROM events
WHERE event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed')
  AND isNotNull(coalesce(toString(properties.task_id), toString(properties.task)))
  AND timestamp >= toStartOfDay(now() - interval 7 day, 'America/Los_Angeles')"
`;
