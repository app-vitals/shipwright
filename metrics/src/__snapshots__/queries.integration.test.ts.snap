  AND timestamp >= toDateTime('2026-03-01 00:00:00', 'America/Los_Angeles') AND timestamp <= toDateTime('2026-04-01 23:59:59', 'America/Los_Angeles')
GROUP BY period
ORDER BY period ASC"
`;

exports[`buildTrendsQuery hour grouping uses toStartOfHour 1`] = `
"SELECT
  toStartOfHour(toTimeZone(timestamp, 'America/Los_Angeles')) AS period,
  countIf(event IN ('shipwright_task_merged', 'shipwright_task_complete', 'shipwright_task_completed')) AS tasks_completed,
