---
// DocsLayout — wraps BaseLayout with docs-specific chrome:
//   • Sidebar nav (all docs sections grouped by section/sorted by order)
//   • Static on-page TOC (headings list, no scroll-spy)
//   • Prev/next bar driven by frontmatter
//   • Mobile sidebar toggle via CSS-only hidden-checkbox pattern
//   • ZERO <script> tags
import { getCollection } from "astro:content";
import "../styles/brand.css";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  section: string;
  prev?: string;
  next?: string;
  headings: Heading[];
}

const { title, description, prev, next, headings } = Astro.props;

// Load all docs entries for the sidebar, sorted by section then order.
const allDocs = await getCollection("docs");
allDocs.sort((a, b) => {
  if (a.data.section !== b.data.section) {
    return a.data.section.localeCompare(b.data.section);
  }
  return a.data.order - b.data.order;
});

// Group by section for sidebar rendering.
const sections: Record<string, typeof allDocs> = {};
for (const doc of allDocs) {
  const s = doc.data.section;
  if (!sections[s]) sections[s] = [];
  sections[s].push(doc);
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-default-1280x640.png", Astro.site);
const year = new Date().getFullYear();

// Filter to headings depth 2 and 3 for the TOC.
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const repoUrl = "https://github.com/app-vitals/shipwright";
const licenseUrl = "https://github.com/app-vitals/shipwright/blob/main/LICENSE";
const claudeCodeUrl = "https://claude.com/claude-code";
const discussionsUrl = "https://github.com/app-vitals/shipwright/discussions";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — Shipwright Harness</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/shipwright-icon.svg" />
    <link rel="icon" type="image/png" href="/shipwright-icon.png" />
    <link rel="apple-touch-icon" href="/shipwright-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — Shipwright Harness`} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Shipwright Harness" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap"
      rel="stylesheet"
    />

    <style>
      /* Mobile sidebar toggle — CSS-only, zero JS */
      #docs-sidebar-toggle {
        display: none;
      }

      .docs-sidebar-overlay {
        display: none;
      }

      @media (max-width: 767px) {
        .docs-sidebar {
          position: fixed;
          top: 0;
          left: -100%;
          width: 280px;
          height: 100vh;
          z-index: 50;
          background: var(--sw-color-bg-raised);
          border-right: 1px solid var(--sw-color-border-muted);
          transition: left 0.25s ease;
          overflow-y: auto;
          padding: 1.5rem;
        }

        #docs-sidebar-toggle:checked ~ .docs-layout .docs-sidebar {
          left: 0;
        }

        #docs-sidebar-toggle:checked ~ .docs-sidebar-overlay {
          display: block;
          position: fixed;
          inset: 0;
          z-index: 40;
          background: rgba(0, 0, 0, 0.5);
        }

        .docs-mobile-menu-btn {
          display: flex;
        }

        .docs-mobile-close-btn {
          display: flex;
        }
      }

      @media (min-width: 768px) {
        .docs-mobile-menu-btn {
          display: none;
        }

        .docs-mobile-close-btn {
          display: none;
        }

        .docs-sidebar {
          position: sticky;
          top: 1.5rem;
          height: fit-content;
          max-height: calc(100vh - 3rem);
          overflow-y: auto;
        }
      }

      /* Layout grid */
      .docs-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        min-height: calc(100vh - 80px);
      }

      @media (min-width: 768px) {
        .docs-layout {
          grid-template-columns: 260px 1fr 220px;
          gap: 2rem;
          align-items: start;
        }
      }

      /* Sidebar link styles */
      .docs-sidebar-link {
        display: block;
        padding: 0.3rem 0.75rem;
        border-radius: var(--sw-radius-sm);
        font-size: var(--sw-text-small-size);
        color: var(--sw-color-text-editorial);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
      }

      .docs-sidebar-link:hover,
      .docs-sidebar-link[aria-current="page"] {
        background: var(--sw-color-bg-overlay);
        color: var(--sw-color-text-heading);
      }

      .docs-sidebar-link[aria-current="page"] {
        color: var(--sw-color-brand-default);
        font-weight: 500;
      }

      /* TOC link styles */
      .docs-toc-link {
        display: block;
        padding: 0.2rem 0;
        font-size: var(--sw-text-small-size);
        color: var(--sw-color-text-editorial);
        text-decoration: none;
        line-height: 1.4;
      }

      .docs-toc-link:hover {
        color: var(--sw-color-text-heading);
      }

      .docs-toc-link.depth-3 {
        padding-left: 0.75rem;
        font-size: 0.8125rem;
        color: var(--sw-color-text-muted);
      }

      /* Prev/next bar */
      .docs-prevnext {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        padding-top: 2rem;
        margin-top: 2rem;
        border-top: 1px solid var(--sw-color-border-subtle);
        flex-wrap: wrap;
      }

      .docs-prevnext a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 1rem;
        border-radius: var(--sw-radius-md);
        border: 1px solid var(--sw-color-border-muted);
        background: var(--sw-color-bg-raised);
        color: var(--sw-color-text-body);
        font-size: var(--sw-text-small-size);
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
      }

      .docs-prevnext a:hover {
        border-color: var(--sw-color-brand-default);
        color: var(--sw-color-brand-default);
      }
    </style>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- Mobile sidebar toggle (CSS-only, hidden checkbox) -->
    <input type="checkbox" id="docs-sidebar-toggle" aria-hidden="true" />

    <!-- Overlay (click to close — uses label trick; CSS-only) -->
    <label
      for="docs-sidebar-toggle"
      class="docs-sidebar-overlay"
      aria-hidden="true"
    ></label>

    <!-- Glow orb (decorative) -->
    <div
      class="sw-orb sw-orb-brand"
      aria-hidden="true"
      style="top: -12rem; left: 50%; width: 42rem; height: 42rem; transform: translateX(-50%);"
    >
    </div>

    <!-- Site header -->
    <header
      class="sw-container relative z-10 flex items-center justify-between py-6"
    >
      <a
        href="/"
        class="flex items-center gap-3"
        aria-label="Shipwright Harness — home"
      >
        <img
          src="/shipwright-icon.svg"
          alt=""
          width="36"
          height="36"
          class="rounded-lg"
        />
        <span
          class="text-lg"
          style="font-family: var(--sw-font-display); font-weight: 700; letter-spacing: -0.01em; color: var(--sw-color-text-heading);"
        >
          Shipwright <span style="color: var(--sw-color-brand-default);"
            >Harness</span
          >
        </span>
      </a>
      <nav class="flex items-center gap-6" aria-label="Primary">
        <a href="/docs/getting-started" class="sw-label">Docs</a>
        <a href="/compare" class="sw-label">Compare</a>
        <a href={repoUrl} class="sw-label">GitHub ↗</a>
      </nav>
    </header>

    <!-- Main docs layout -->
    <div class="sw-container relative z-10 pb-20">
      <!-- Mobile: hamburger button -->
      <div class="docs-mobile-menu-btn py-4">
        <label
          for="docs-sidebar-toggle"
          class="sw-btn sw-btn-secondary"
          style="cursor: pointer; font-size: var(--sw-text-small-size); padding: 0.4rem 0.75rem;"
          aria-label="Open navigation"
        >
          ☰ Menu
        </label>
      </div>

      <div class="docs-layout">
        <!-- Sidebar -->
        <aside class="docs-sidebar">
          <!-- Mobile close button -->
          <div class="docs-mobile-close-btn" style="justify-content: flex-end; margin-bottom: 1rem;">
            <label
              for="docs-sidebar-toggle"
              style="cursor: pointer; color: var(--sw-color-text-editorial); font-size: var(--sw-text-small-size);"
              aria-label="Close navigation"
            >
              ✕ Close
            </label>
          </div>

          <nav aria-label="Docs navigation">
            {
              Object.entries(sections).map(([sectionName, docs]) => (
                <div style="margin-bottom: 1.5rem;">
                  <p
                    class="sw-label"
                    style="margin-bottom: 0.5rem; padding-left: 0.75rem;"
                  >
                    {sectionName}
                  </p>
                  <ul style="list-style: none; margin: 0; padding: 0;">
                    {docs.map((doc) => {
                      const slug = doc.id.replace(/\.(mdx?|md)$/, "");
                      const href = `/docs/${slug}`;
                      const isCurrent =
                        Astro.url.pathname === href ||
                        Astro.url.pathname === href + "/";
                      return (
                        <li>
                          <a
                            href={href}
                            class="docs-sidebar-link"
                            aria-current={isCurrent ? "page" : undefined}
                          >
                            {doc.data.title}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))
            }
          </nav>
        </aside>

        <!-- Main content -->
        <main class="sw-prose" style="min-width: 0;">
          <slot />

          <!-- Prev/next navigation -->
          {
            (prev || next) && (
              <div class="docs-prevnext">
                {prev ? (
                  <a href={prev} data-nav="prev">
                    ← Previous
                  </a>
                ) : (
                  <span />
                )}
                {next && (
                  <a href={next} data-nav="next">
                    Next →
                  </a>
                )}
              </div>
            )
          }
        </main>

        <!-- TOC (on-page, static) -->
        {
          tocHeadings.length > 0 && (
            <aside
              style="min-width: 0;"
            >
              <nav aria-label="On this page">
                <p
                  class="sw-label"
                  style="margin-bottom: 0.75rem;"
                >
                  On this page
                </p>
                <ul style="list-style: none; margin: 0; padding: 0;">
                  {tocHeadings.map((heading) => (
                    <li>
                      <a
                        href={`#${heading.slug}`}
                        class={`docs-toc-link depth-${heading.depth}`}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }
      </div>
    </div>

    <!-- Footer -->
    <footer class="sw-container relative z-10 py-12">
      <div
        class="flex flex-col gap-6 pt-8 sm:flex-row sm:items-center sm:justify-between"
        style="border-top: 1px solid var(--sw-color-border-subtle);"
      >
        <p class="sw-label flex items-center gap-2">
          <img
            src="/shipwright-icon.svg"
            alt=""
            width="20"
            height="20"
            class="rounded"
          />
          Shipwright Harness · MIT-licensed · © {year}
        </p>
        <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm" aria-label="Footer">
          <a href={repoUrl}>GitHub</a>
          <a href={licenseUrl}>MIT License</a>
          <a href={claudeCodeUrl}>Claude Code</a>
          <a href={discussionsUrl}>GitHub Discussions</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
