---
// Home page — hero, two-ways, problem, how-it-works, differentiators, demo,
// social proof (SWW-2.1 + SWW-2.2).
// No runtime JS, no hardcoded hex colors, no competitor names.
import BaseLayout from "../layouts/BaseLayout.astro";

const taglinePrefix = "The open-source autonomous delivery system ";
const taglineGradient = "in your own environment";
const tagline = `${taglinePrefix}${taglineGradient}.`;
const install = "/plugin install shipwright@app-vitals/shipwright";
const githubUrl = "https://github.com/app-vitals/shipwright";
const discoveryUrl = "https://cal.com/team/app-vitals/discovery-call";
const proofUrl = "https://proof.shipwrightharness.com/public/dashboard";
const proofTasksUrl = "https://proof.shipwrightharness.com/public/tasks";

// Two ways to run it: the plugin (in Claude Code) and the cloud agent (in your cloud).
// Both run the same autonomous coding system; only the surface differs.
const pillars = [
  {
    kind: "plugin",
    num: "01",
    name: "The plugin",
    surface: "In Claude Code",
    title: "Drive it at your prompt",
    body: "Install it into Claude Code and run the full loop — spec → plan → build → review → deploy — on any repository. It writes the feature and its tests, opens the PR, and ships, autonomously, with you in the loop where it counts.",
    points: [
      "End to end — planning through deployment",
      "Repo-agnostic — Node, Go, Rust, Python, Ruby",
      "Driven by /shipwright:* commands",
    ],
  },
  {
    kind: "agent",
    num: "02",
    name: "The cloud agent",
    surface: "In your cloud",
    title: "Talk to it in Slack. It ships on a schedule.",
    body: "Deploy the same system to your cloud as an agent you reach in Slack — DM it, @mention it in a thread, drop a voice note. It runs on a pool of scheduled jobs, picking up ready work and shipping PRs on its own — coding while you're away, at the same review and test bar.",
    points: [
      "Slack-native — DMs, mentions, voice notes, reactions",
      "Cron-driven — two jobs on by default, ten in the pool",
      "Deploys on Docker and Kubernetes",
    ],
  },
];

// Default cron jobs the cloud agent seeds onto every new agent.
// Source of truth: admin/src/system-crons.ts (keep this list in sync).
const crons = [
  {
    name: "dev-task",
    cadence: "every 30 min",
    on: true,
    desc: "Picks the next ready task, builds it with tests, opens a PR.",
  },
  {
    name: "review-patch",
    cadence: "every 30 min",
    on: true,
    desc: "Reviews open PRs and patches the ones failing CI or review.",
  },
  {
    name: "review",
    cadence: "every 30 min",
    on: false,
    desc: "Review-only pass over open PRs.",
  },
  {
    name: "patch",
    cadence: "every 30 min",
    on: false,
    desc: "Fixes failing CI and unresolved review findings.",
  },
  {
    name: "deploy",
    cadence: "every 30 min",
    on: false,
    desc: "Merges approved PRs and deploys them.",
  },
  {
    name: "test-readiness",
    cadence: "daily · 6am",
    on: false,
    desc: "Audits test coverage and publishes the report.",
  },
  {
    name: "docs-freshness",
    cadence: "daily · 7am",
    on: false,
    desc: "Refreshes docs that drifted from the code.",
  },
  {
    name: "learn-dream",
    cadence: "daily · 3am",
    on: false,
    desc: "Mines merged PRs for durable learnings.",
  },
  {
    name: "dependabot-triage",
    cadence: "daily · 8am",
    on: false,
    desc: "Reviews and triages Dependabot PRs.",
  },
  {
    name: "entropy-patrol",
    cadence: "weekly · Mon",
    on: false,
    desc: "Scans for code entropy and fixes what's PR-worthy.",
  },
];

// Metrics section — REAL figures, pulled at build time from the public proof
// dashboard for this repo (https://proof.shipwrightharness.com). The fallback
// snapshot below is the last-known real data, so a build never breaks if the
// dashboard is briefly unavailable. Window = last 7 days (where this repo's
// activity lives); see docs/metrics.md for the endpoint contract.
const PROOF_METRICS_BASE = "https://proof.shipwrightharness.com/public/metrics";
const PROOF_PRESET = "7d";
const METRICS_WINDOW_LABEL = "last 7 days";

type ProofSummary = {
  tasksCompleted: number;
  avgCycleTimeHours: number | null;
  reviewShipItRate: number | null;
  estimationAccuracy: number | null;
};
type ProofTrendPoint = { period: string; tasksCompleted: number };

// Last-known real snapshot (build-time fallback only).
const summaryFallback: ProofSummary = {
  tasksCompleted: 86,
  avgCycleTimeHours: 2.617,
  reviewShipItRate: 65.31,
  estimationAccuracy: -3.48,
};
const trendsFallback: ProofTrendPoint[] = [
  { period: "2026-06-24", tasksCompleted: 22 },
  { period: "2026-06-25", tasksCompleted: 27 },
  { period: "2026-06-26", tasksCompleted: 8 },
  { period: "2026-06-27", tasksCompleted: 12 },
  { period: "2026-06-28", tasksCompleted: 10 },
  { period: "2026-06-29", tasksCompleted: 6 },
];

async function fetchProof<T>(path: string, fallback: T): Promise<T> {
  try {
    const res = await fetch(`${PROOF_METRICS_BASE}${path}`, {
      signal: AbortSignal.timeout(8000),
      headers: { accept: "application/json" },
    });
    if (!res.ok) return fallback;
    const json = (await res.json()) as { data?: unknown };
    return (json.data as T) ?? fallback;
  } catch {
    return fallback;
  }
}

const summary = await fetchProof<ProofSummary>(
  `/summary?preset=${PROOF_PRESET}`,
  summaryFallback,
);
const trendsData = await fetchProof<{ rows?: ProofTrendPoint[] }>(
  `/trends?preset=${PROOF_PRESET}&groupBy=day`,
  { rows: trendsFallback },
);
const trendRows =
  trendsData.rows && trendsData.rows.length > 0
    ? trendsData.rows
    : trendsFallback;

// Format the real summary into the four headline cards.
const fmtCycle = (h: number | null) =>
  h == null ? "—" : h >= 24 ? `${(h / 24).toFixed(1)}d` : `${h.toFixed(1)}h`;
const fmtPct = (n: number | null) => (n == null ? "—" : `${Math.round(n)}%`);
const fmtSignedPct = (n: number | null) =>
  n == null ? "—" : `${n > 0 ? "+" : n < 0 ? "−" : ""}${Math.abs(n).toFixed(1)}%`;

const metricStats = [
  {
    value: String(summary.tasksCompleted),
    label: "Tasks shipped",
    note: "merged PRs",
  },
  {
    value: fmtCycle(summary.avgCycleTimeHours),
    label: "Avg cycle time",
    note: "task → shipped",
  },
  {
    value: fmtPct(summary.reviewShipItRate),
    label: "Review ship-it rate",
    note: "approved on first review",
  },
  {
    value: fmtSignedPct(summary.estimationAccuracy),
    label: "Estimation accuracy",
    note: "actual vs. planned (0% = perfect)",
  },
];
// Real per-day throughput → relative bar heights (%).
const trendMax = Math.max(...trendRows.map((r) => r.tasksCompleted), 1);
const metricBars = trendRows.map((r) =>
  Math.round((r.tasksCompleted / trendMax) * 100),
);

// "Inside a task" tab — the ordered steps /shipwright:dev-task runs.
// Faithful to plugins/shipwright/commands/dev-task.md (its phase headings).
const devTaskSteps = [
  {
    n: "01",
    title: "Detect the toolchain",
    body: "Scan the repo's build config and extract the test, lint, typecheck, and validate commands to use later.",
  },
  {
    n: "02",
    title: "Pick the next task",
    body: "Resume an in-progress task, or pull the next ready item from the queue and validate its fields.",
  },
  {
    n: "03",
    title: "Mark in-progress",
    body: "Clean up any orphaned branches or PRs from a prior run, then flip the task's status label.",
  },
  {
    n: "04",
    title: "Build the brief",
    body: "Assemble a spec prompt from the task's title, description, acceptance criteria, and layer.",
  },
  {
    n: "05",
    title: "Set up a worktree",
    body: "Create or reuse an isolated git worktree on the task's branch — never on main.",
  },
  {
    n: "06",
    title: "Tests first, then code",
    body: "Write failing tests, make them pass, then refactor. No production code before a failing test exists.",
  },
  {
    n: "07",
    title: "Simplify",
    body: "Review the diff for duplication, dead code, naming, and needless complexity — and fix it.",
  },
  {
    n: "08",
    title: "Verify the spec",
    body: "An independent subagent checks every acceptance criterion against the diff and auto-fixes gaps.",
  },
  {
    n: "09",
    title: "Grade requirements",
    body: "Score each criterion met / partial / not-met, and block the task if anything is unmet after fixes.",
  },
  {
    n: "10",
    title: "Pre-ship checks",
    body: "Run validate, lint, test, and typecheck, and report the coverage delta against the threshold.",
  },
  {
    n: "11",
    title: "Refresh the docs",
    body: "A docs agent updates any docs the change made stale, in a separate commit on the branch.",
  },
  {
    n: "12",
    title: "Push & open the PR",
    body: "Push the branch and open a pull request — or add commits to the existing one.",
  },
  {
    n: "13",
    title: "Watch CI, fix failures",
    body: "Poll CI, collect failure logs, and retry fixes up to six times before blocking the task.",
  },
  {
    n: "14",
    title: "Record metrics & hand off",
    body: "Move the task to pr_open, append the metrics line, and print a handoff summary.",
  },
];

// How-it-works: the four pipeline stages (plan → build → review → ship).
const stages = [
  {
    name: "Plan",
    body: "Read the spec, explore the codebase, and emit a sequenced task queue with estimates.",
  },
  {
    name: "Build",
    body: "Pick the next ready task, branch, write the feature and its tests at the correct layer.",
  },
  {
    name: "Review",
    body: "Deep single-pass review with inline findings and a recorded verdict before anything merges.",
  },
  {
    name: "Ship",
    body: "Merge the green PR, deploy, and forward the metrics that close the feedback loop.",
  },
];

// Differentiators: generic, no competitor names. Claude Code is the platform.
const differentiators = [
  {
    label: "Own it",
    title: "Free & open-source (MIT)",
    body: "No tiers, no seats, no data leaving your control. Clone it, run it in your own cloud, fork it if you want to.",
  },
  {
    label: "Test-readiness",
    title: "Tests land with the code",
    body: "Every task ships its tests at the correct layer — unit, integration, smoke, or e2e — in the same PR. No 'tests later'.",
  },
  {
    label: "Metric-first",
    title: "Measured, not vibes",
    body: "First-time-quality, estimation accuracy, and review verdicts are tracked per task so the pipeline gets honestly better.",
  },
  {
    label: "Repo-agnostic",
    title: "Runs on your stack",
    body: "Node, Rust, Go, Python, Ruby, Make — the plugin drives any repository it's pointed at, not a blessed template.",
  },
];

---

<BaseLayout
  description={tagline}
  pagefindIgnore={true}
>
  <!-- ── Hero ── (tagline + intro video) -->
  <section class="relative z-10 pt-12 pb-12 text-center">
    <p class="sw-label">Built on Claude Code</p>
    <h1 class="sw-display mt-4 max-w-3xl mx-auto">
      {taglinePrefix}<span class="sw-gradient-text">{taglineGradient}</span>.
    </h1>

    <!-- Intro video — hero centerpiece. -->
    <div class="mt-10 w-full max-w-5xl mx-auto">
      <video
        src="/shipwright-intro.mp4"
        poster="/shipwright-intro-poster.jpg"
        controls
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        width="1920"
        height="1080"
        class="w-full rounded-2xl"
        style="border: 1px solid var(--sw-color-border-muted);"
        aria-label="Shipwright Harness intro: the open-source autonomous delivery agent for Claude Code."
      ></video>
    </div>
  </section>

  <!-- Showcase: four tabbed panels (Two ways · Crons · Metrics · Demo).
       CSS-only tabs via the radio-input pattern — no runtime JS. -->
  <section id="showcase" class="relative z-10 pt-6 pb-24">
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-two-ways" checked />
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-devtask" />
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-crons" />
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-metrics" />
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-proof" />
    <input class="sw-tab-input" type="radio" name="sw-showcase" id="sw-tab-demo" />

    <div class="sw-tablist" role="tablist" aria-label="Product showcase">
      <label class="sw-tab" for="sw-tab-two-ways">Two ways to run it</label>
      <label class="sw-tab" for="sw-tab-devtask">Inside a task</label>
      <label class="sw-tab" for="sw-tab-crons">Ships on a schedule</label>
      <label class="sw-tab" for="sw-tab-metrics">Metrics</label>
      <label class="sw-tab" for="sw-tab-proof">Proof</label>
      <label class="sw-tab" for="sw-tab-demo">Run the full stack</label>
    </div>

    <div class="sw-panels">
      <!-- Panel: Two ways to run it -->
      <div id="two-ways" class="sw-panel sw-panel--two-ways">
        <!-- Centered header: make the "one system, two surfaces" idea unmistakable. -->
    <div class="flex flex-col items-center text-center">
      <p class="sw-label">Two ways to run it</p>
      <h2 class="sw-h1 mt-3 max-w-3xl">
        One system. <span class="sw-gradient-text">A plugin and a cloud agent.</span>
      </h2>
      <p class="mt-5 max-w-2xl text-lg">
        The same autonomous coding system, two ways to put it to work — drive it
        yourself from Claude Code, or deploy it to your cloud and let it ship on
        its own.
      </p>
    </div>

    <!-- Two pillars with a centered "+" connector: plugin + agent = one system. -->
    <div class="relative mt-12 grid items-stretch gap-6 lg:grid-cols-2">
      <!-- Connector badge (lg only): visually fuses the two cards into one system. -->
      <div
        class="pointer-events-none absolute left-1/2 top-1/2 z-20 hidden -translate-x-1/2 -translate-y-1/2 lg:flex"
        aria-hidden="true"
      >
        <span
          class="flex h-14 w-14 items-center justify-center rounded-full text-2xl"
          style="background: var(--sw-color-bg-overlay); border: 1px solid var(--sw-color-border-strong);"
        >
          <span class="sw-gradient-text">+</span>
        </span>
      </div>

      {
        pillars.map((p) => {
          const accent =
            p.kind === "agent"
              ? "var(--sw-color-support-patriot-bright)"
              : "var(--sw-color-brand-default)";
          return (
            <div
              class="sw-card flex flex-col gap-4"
              style={`border-top: 2px solid ${accent};`}
            >
              {/* Header: glyph + surface label + big number */}
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span
                    class="flex h-11 w-11 items-center justify-center rounded-lg"
                    style={`background: var(--sw-color-bg-overlay); color: ${accent};`}
                  >
                    {p.kind === "plugin" ? (
                      <svg
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polyline points="5 8 9 12 5 16" />
                        <line x1="12" y1="16" x2="18" y2="16" />
                      </svg>
                    ) : (
                      <svg
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8 8.4 8.4 0 0 1 8.5-8.5 8.5 8.5 0 0 1 8.5 8.5z" />
                      </svg>
                    )}
                  </span>
                  <div class="text-left">
                    <p class="text-lg" style={`color: ${accent};`}>{p.name}</p>
                    <p class="sw-label">{p.surface}</p>
                  </div>
                </div>
                <span
                  class="sw-mono text-2xl"
                  style="color: var(--sw-color-text-muted);"
                >
                  {p.num}
                </span>
              </div>

              <h3 class="text-2xl">{p.title}</h3>
              <p>{p.body}</p>

              {/* Mini-visual: terminal for the plugin, a Slack thread for the agent */}
              {p.kind === "plugin" ? (
                <pre class="sw-code text-sm leading-relaxed"><code>$ /shipwright:dev-task
→ build · test · review · ship
✓ PR #128 opened</code></pre>
              ) : (
                <div
                  class="flex flex-col gap-2 rounded-lg p-3"
                  style="background: var(--sw-color-bg-overlay); border: 1px solid var(--sw-color-border-muted);"
                >
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded text-xs"
                      style="background: var(--sw-color-border-strong); color: var(--sw-color-text-body);"
                    >
                      you
                    </span>
                    <p class="text-sm">@shipwright take the next ready task</p>
                  </div>
                  <div class="flex items-start gap-2">
                    <img
                      src="/shipwright-icon.svg"
                      alt=""
                      width="24"
                      height="24"
                      class="mt-0.5 shrink-0 rounded"
                    />
                    <p class="text-sm">
                      <span style="color: var(--sw-color-brand-default);">✓</span>{" "}
                      Shipped <strong>PR #128</strong> — reviewed, tests green,
                      deployed.
                    </p>
                  </div>
                </div>
              )}

              <ul class="mt-1 flex flex-col gap-2">
                {p.points.map((pt) => (
                  <li class="flex gap-2">
                    <span style={`color: ${accent};`} aria-hidden="true">→</span>
                    <span>{pt}</span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>

    <!-- Tie both pillars back to the shared engine. -->
    <p class="mt-8 text-center">
      <a href="#how-it-works">Either way, the same four-stage engine ships it →</a>
    </p>
      </div>

      <!-- Panel: Ships on a schedule -->
      <div id="crons" class="sw-panel sw-panel--crons">
    <p class="sw-label">Ships on a schedule</p>
    <h2 class="sw-h1 mt-3 max-w-2xl">
      Ten cron jobs, ready out of the box.
    </h2>
    <p class="mt-5 max-w-2xl text-lg">
      Every cloud agent is seeded with ten scheduled jobs. Two run from day
      one; the rest are a single toggle away. Each guards itself with a
      pre-check, so it only spends a turn when there's real work to do.
    </p>

    <div class="mt-10 grid gap-3 sm:grid-cols-2">
      {
        crons.map((c) => (
          <div class="sw-card flex items-start justify-between gap-4 py-4">
            <div class="flex flex-col gap-1">
              <code
                class="sw-mono text-sm"
                style="color: var(--sw-color-text-heading);"
              >
                {c.name}
              </code>
              <p class="text-sm">{c.desc}</p>
              <p class="sw-label">{c.cadence}</p>
            </div>
            <span class={c.on ? "sw-pill sw-pill-success" : "sw-pill"}>
              {c.on ? "On" : "Opt-in"}
            </span>
          </div>
        ))
      }
    </div>
      </div>

      <!-- Panel: Metrics -->
      <div id="metrics" class="sw-panel sw-panel--metrics">
    <p class="sw-label">Measured, not vibes</p>
    <h2 class="sw-h1 mt-3 max-w-2xl">
      A dashboard that grades the work.
    </h2>
    <p class="mt-5 max-w-2xl text-lg">
      Every task emits telemetry — first-time-quality, estimation accuracy,
      review verdicts, cycle time, and token cost — to a dashboard you host
      yourself. PostHog, Postgres, or a local SQLite store; no data leaves your
      control.
    </p>

    <!-- Simulated dashboard screenshot (on-brand mock, no runtime JS). -->
    <div
      class="mt-10 overflow-hidden rounded-xl"
      style="background: var(--sw-color-bg-raised); border: 1px solid var(--sw-color-border-muted);"
      role="img"
      aria-label="Live Shipwright metrics for this repo: tasks shipped, cycle time, review ship-it rate, estimation accuracy, and a per-day throughput chart."
    >
      <!-- Window chrome -->
      <div
        class="flex items-center gap-3 px-4 py-3"
        style="border-bottom: 1px solid var(--sw-color-border-subtle);"
      >
        <span class="flex gap-1.5" aria-hidden="true">
          <span
            class="h-3 w-3 rounded-full"
            style="background: var(--sw-color-border-strong);"></span>
          <span
            class="h-3 w-3 rounded-full"
            style="background: var(--sw-color-border-strong);"></span>
          <span
            class="h-3 w-3 rounded-full"
            style="background: var(--sw-color-border-strong);"></span>
        </span>
        <span class="sw-label">shipwright metrics · {METRICS_WINDOW_LABEL}</span>
      </div>

      <!-- Dashboard body -->
      <div class="p-5">
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            metricStats.map((s) => (
              <div
                class="rounded-lg p-4"
                style="background: var(--sw-color-bg-overlay); border-top: 2px solid var(--sw-color-brand-default);"
              >
                <p class="sw-stat" style="color: var(--sw-color-text-heading);">
                  {s.value}
                </p>
                <p class="sw-label mt-1">{s.label}</p>
                <p
                  class="mt-1 text-sm"
                  style="color: var(--sw-color-text-muted);"
                >
                  {s.note}
                </p>
              </div>
            ))
          }
        </div>

        <!-- Throughput chart (pure-CSS bars) -->
        <div
          class="mt-4 rounded-lg p-4"
          style="background: var(--sw-color-bg-overlay);"
        >
          <div class="flex items-center justify-between">
            <p class="sw-label">Tasks shipped per day</p>
            <p class="sw-label" style="color: var(--sw-color-brand-default);">
              {METRICS_WINDOW_LABEL}
            </p>
          </div>
          <div class="mt-4 flex h-24 items-end gap-2" aria-hidden="true">
            {
              metricBars.map((h) => (
                <div
                  class="flex-1 rounded-t"
                  style={`height: ${h}%; background: linear-gradient(180deg, var(--sw-color-brand-default), var(--sw-color-brand-strong));`}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <p class="mt-4 text-sm" style="color: var(--sw-color-text-muted);">
      Real figures for this repo, pulled from the public proof dashboard —{" "}
      <a href={proofUrl}>see the live dashboard</a>, or run{" "}
      <code class="sw-mono">task api</code> to run it on your own data.
    </p>
      </div>

      <!-- Panel: Proof — dogfooding + public dashboard -->
      <div id="proof" class="sw-panel sw-panel--proof">
    <p class="sw-label">True dogfooding</p>
    <h2 class="sw-h1 mt-4 max-w-2xl">
      Shipwright builds Shipwright.
    </h2>
    <p class="mt-5 max-w-2xl text-lg">
      This repository is delivered by the Shipwright agent itself — the same
      autonomous loop you install. Every task, PR, review verdict, and metric on
      this page comes from that loop building its own codebase. None of it is
      staged: the queue and the numbers are public, live, and updated as the
      agent ships.
    </p>

