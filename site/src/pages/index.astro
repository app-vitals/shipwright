  <!--
    Animated Slack thread styling (cloud-agent demo). Pure CSS keyframes — NO
    runtime JS. Messages are visible by default (and for reduced-motion users);
    the staggered reveal only runs when motion is allowed.
  -->
  <style>
    /* CSS-only tabs (radio-input pattern) — switches panels with NO runtime JS. */
    .sw-tab-input {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
    }
    .sw-tablist {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }
    .sw-tab {
      cursor: pointer;
      user-select: none;
      padding: 0.5rem 1rem;
      border-radius: 9999px;
      border: 1px solid var(--sw-color-border-muted);
      color: var(--sw-color-text-body);
      font-size: 0.875rem;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .sw-tab:hover {
      border-color: var(--sw-color-border-strong);
    }
    .sw-panel {
      display: none;
      padding-top: 2.5rem;
    }
    /* Active tab label (checked radio) → green fill, navy text. */
    #sw-tab-two-ways:checked ~ .sw-tablist label[for="sw-tab-two-ways"],
    #sw-tab-devtask:checked ~ .sw-tablist label[for="sw-tab-devtask"],
    #sw-tab-crons:checked ~ .sw-tablist label[for="sw-tab-crons"],
    #sw-tab-metrics:checked ~ .sw-tablist label[for="sw-tab-metrics"],
    #sw-tab-proof:checked ~ .sw-tablist label[for="sw-tab-proof"],
    #sw-tab-demo:checked ~ .sw-tablist label[for="sw-tab-demo"] {
      background: var(--sw-color-brand-default);
      border-color: var(--sw-color-brand-default);
      color: var(--sw-color-brand-on-brand-text);
    }
    /* Keyboard focus ring on the focused tab. */
    #sw-tab-two-ways:focus-visible ~ .sw-tablist label[for="sw-tab-two-ways"],
    #sw-tab-devtask:focus-visible ~ .sw-tablist label[for="sw-tab-devtask"],
    #sw-tab-crons:focus-visible ~ .sw-tablist label[for="sw-tab-crons"],
    #sw-tab-metrics:focus-visible ~ .sw-tablist label[for="sw-tab-metrics"],
    #sw-tab-proof:focus-visible ~ .sw-tablist label[for="sw-tab-proof"],
    #sw-tab-demo:focus-visible ~ .sw-tablist label[for="sw-tab-demo"] {
      outline: 2px solid var(--sw-color-support-patriot-bright);
      outline-offset: 2px;
    }
    /* Show only the active panel. */
    #sw-tab-two-ways:checked ~ .sw-panels .sw-panel--two-ways,
    #sw-tab-devtask:checked ~ .sw-panels .sw-panel--devtask,
    #sw-tab-crons:checked ~ .sw-panels .sw-panel--crons,
    #sw-tab-metrics:checked ~ .sw-panels .sw-panel--metrics,
    #sw-tab-proof:checked ~ .sw-panels .sw-panel--proof,
    #sw-tab-demo:checked ~ .sw-panels .sw-panel--demo {
      display: block;
    }

    .sw-slack-av {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 24px;
      width: 24px;
      flex-shrink: 0;
      border-radius: 6px;
      font-size: 11px;
    }
    .sw-dots {
      display: inline-flex;
      gap: 4px;
    }
    .sw-dots i {
      display: block;
      width: 6px;
      height: 6px;
      border-radius: 9999px;
      background: var(--sw-color-text-muted);
    }
    /* Typing indicator is hidden by default; only the animation reveals it. */
    .sw-slack-typing {
      opacity: 0;
    }

    @media (prefers-reduced-motion: no-preference) {
      .sw-slack-msg,
      .sw-slack-react {
        opacity: 0;
      }
      .sw-slack-msg--1 {
        animation: sw-msg-1 14s infinite;
      }
      .sw-slack-msg--2 {
        animation: sw-msg-2 14s infinite;
      }
      .sw-slack-msg--3 {
        animation: sw-msg-3 14s infinite;
      }
      .sw-slack-msg--4 {
        animation: sw-msg-4 14s infinite;
      }
      .sw-slack-typing {
        animation: sw-typing 14s infinite;
      }
      .sw-slack-react {
        animation: sw-react 14s infinite;
      }
      .sw-dots i {
        animation: sw-dot 1.2s infinite;
      }
      .sw-dots i:nth-child(2) {
        animation-delay: 0.15s;
      }
      .sw-dots i:nth-child(3) {
        animation-delay: 0.3s;
      }
    }

    @keyframes sw-msg-1 {
      0%, 3% { opacity: 0; transform: translateY(8px); }
      6%, 94% { opacity: 1; transform: none; }
      99%, 100% { opacity: 0; }
    }
    @keyframes sw-msg-2 {
      0%, 19% { opacity: 0; transform: translateY(8px); }
      23%, 94% { opacity: 1; transform: none; }
      99%, 100% { opacity: 0; }
    }
    @keyframes sw-msg-3 {
      0%, 31% { opacity: 0; transform: translateY(8px); }
      35%, 94% { opacity: 1; transform: none; }
      99%, 100% { opacity: 0; }
    }
    @keyframes sw-msg-4 {
      0%, 43% { opacity: 0; transform: translateY(8px); }
      47%, 94% { opacity: 1; transform: none; }
      99%, 100% { opacity: 0; }
    }
    @keyframes sw-typing {
      0%, 11% { opacity: 0; }
      13%, 18% { opacity: 1; }
      21%, 100% { opacity: 0; }
    }
    @keyframes sw-react {
      0%, 55% { opacity: 0; transform: scale(0.5); }
      60%, 94% { opacity: 1; transform: scale(1); }
      99%, 100% { opacity: 0; }
    }
    @keyframes sw-dot {
      0%, 80%, 100% { transform: translateY(0); opacity: 0.5; }
      40% { transform: translateY(-3px); opacity: 1; }
    }
  </style>

