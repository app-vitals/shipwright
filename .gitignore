# --- Secrets & environment (never commit) ---
.env
.env.*
!.env.example

# --- Local Claude Code settings — machine-specific (absolute SHIPWRIGHT_CONFIG path) ---
.claude/settings.local.json

# --- Private staged learnings + build-time export specifics (internal) ---
CLAUDE.local.md

# --- Internal planning artifacts — build-time only, not for the public repo ---
planning/

# --- Local JSON task-store state (only written if the github backend isn't active) ---
state/*
# Allow workspace templates that live under agent/workspace/state/
!agent/workspace/state/
# Allow the committed example file for dev-agent credentials
!state/dev-agent.env.example

# --- Database files (local dev only — never commit) ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Prisma generated client (regenerated from schema on install) ---
agent/prisma/client/
admin/prisma/client/

# --- Dependencies ---
node_modules/

# --- Build output ---
dist/
build/

# --- Rendered marketing artifacts (regenerable via the shipwright-brand skill) ---
# Committed assets live in proper homes: assets/, site/public/, brand/assets/.
brand/out/

# --- Test & coverage artifacts ---
coverage/
test-results/
playwright-report/
playwright/.cache/

# --- Logs & temp ---
*.log
*.tmp

# --- OS cruft ---
.DS_Store
Thumbs.db
