state/

# --- Dependencies ---
node_modules/

# --- Stale scaffolding from previous iterations (never commit) ---
metrics/src/lib/

# --- Build output ---
dist/
build/

# --- Test & coverage artifacts ---
coverage/
test-results/
playwright-report/
playwright/.cache/

# --- Logs & temp ---
*.log
*.tmp

# --- OS cruft ---
.DS_Store
Thumbs.db
