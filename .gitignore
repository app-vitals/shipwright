# --- Secrets & environment (never commit) ---
.env
.env.*
!.env.example

# --- Local Claude Code settings — machine-specific (absolute SHIPWRIGHT_CONFIG path) ---
.claude/settings.local.json

# --- Private staged learnings + build-time export specifics (internal) ---
CLAUDE.local.md

# --- Internal planning artifacts — build-time only, not for the public repo ---
planning/

