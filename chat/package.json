{
  "name": "@shipwright/chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "description": "Shipwright chat service — Postgres-backed Thread/Message store + scoped tokens",
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "test": "bun test",
