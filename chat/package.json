    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@shipwright/lib": "*",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "prisma": "^6.19.2",
    "typescript": "*"
  }
}
