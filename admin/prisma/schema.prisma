// Shipwright — Admin Service Schema
// Owns: Agent, AgentEnv, AgentCronJob, AgentTool, AgentToken, AgentPlugin.
// Agent is a first-class model (standalone, not embedded in a User model).
//
// WARNING: This schema uses DATABASE_URL_SHIPWRIGHT_ADMIN — a dedicated database
// for the admin service. Do NOT point this at a shared database.

generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_SHIPWRIGHT_ADMIN")
}

// ─── Agent ────────────────────────────────────────────────────────────────────
// A Shipwright agent: an autonomous runner that picks tasks, builds, and ships PRs.

model Agent {
  id              String   @id @default(cuid())
  name            String
  slackId         String?  @unique
  slackBotToken   String?  // AES-256-GCM encrypted at the service layer
  anthropicApiKey String?  // AES-256-GCM encrypted at the service layer
  selfHosted      Boolean  @default(false)
  repos           String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  envVars          AgentEnv[]
  cronJobs         AgentCronJob[]
  tools            AgentTool[]
  tokens           AgentToken[]
  plugins          AgentPlugin[]
  members          AgentMember[]
  chatTokenUsage   AgentChatTokenUsageDailyByModel[]
}

// ─── Agent Env ────────────────────────────────────────────────────────────────
// Generic key/value env var store for deployed agents.
// Keys are env var names (e.g. ANTHROPIC_API_KEY). Values are AES-256-GCM encrypted.

model AgentEnv {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  key       String   // env var name
  value     String   // AES-256-GCM encrypted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, key])
}

// ─── Agent Cron Jobs ──────────────────────────────────────────────────────────
// Scheduled prompts per agent.
// Delivery target is either a Slack channel ID or a Slack user ID (DM).
// Validation that exactly one of channel/user is set happens in the service layer.

model AgentCronJob {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  schedule  String   // cron expression e.g. "0 9 * * 1-5"
  prompt    String
  channel   String?  // Slack channel ID (mutually exclusive with user)
  user      String?  // Slack user ID for DMs
  silent    Boolean  @default(false)
  enabled   Boolean  @default(true)
  preCheck  String?  // optional pre-check script e.g. "shipwright:check-dev-task.ts"
  name      String?  // stable key for system crons; null for user-created crons
  system    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs AgentCronRun[]
}

// ─── Agent Tools ──────────────────────────────────────────────────────────────
// Allowed tool patterns per agent. Each row grants an agent permission to use
// a specific tool pattern (e.g. "Read", "Bash", "Write"). The unique constraint
// on [agentId, pattern] prevents duplicates.

model AgentTool {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  pattern   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([agentId, pattern])
}

// ─── Agent Tokens ─────────────────────────────────────────────────────────────
// Scoped API tokens for agent authentication. The raw token is returned once at
// creation; only the SHA-256 hash is stored. Token validation is O(1) via the
// hash index.

model AgentToken {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  token     String    @unique // SHA-256 hash of the raw token (hex)
  label     String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

// ─── Agent Plugins ────────────────────────────────────────────────────────────
// Claude Code plugins installed per agent. Each row represents one installed
// plugin package. The unique constraint on [agentId, name] prevents duplicates.

model AgentPlugin {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name      String   // plugin package name e.g. "@shipwright/plugin"
  version   String?  // pinned version; null = latest
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, name])
}

// ─── Agent Members ────────────────────────────────────────────────────────────
// Non-admin users granted web UI access to a specific agent.
// Admins (SHIPWRIGHT_ADMIN_ALLOWED_EMAILS) bypass this table entirely.
// Members can view and edit only the agents they are listed on.

model AgentMember {
  id        String   @id @default(cuid())
  agentId   String
  email     String
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, email])
  @@index([email])
}

// ─── Agent Cron Runs ──────────────────────────────────────────────────────────
// Execution history for AgentCronJob firings. Each row records one cron invocation:
// whether it was skipped (pre-check returned false), the outcome, and any error.
// agentId is denormalized for efficient agent-level history queries.

model AgentCronRun {
  id                 String    @id @default(cuid())
  cronId             String
  cron               AgentCronJob @relation(fields: [cronId], references: [id], onDelete: Cascade)
  agentId            String    // denormalized from cron.agentId for efficient queries
  startedAt          DateTime
  completedAt        DateTime?
  skipped            Boolean   @default(false)
  skipReason         String?
  outcome            String?
  error              String?
  inputTokens        Int?
  outputTokens       Int?
  cacheReadTokens    Int?
  cacheCreationTokens Int?
  createdAt          DateTime  @default(now())

  modelBreakdown AgentCronRunModelBreakdown[]

  @@index([cronId])
  @@index([agentId, startedAt])
}

// ─── Agent Cron Run Model Breakdown ──────────────────────────────────────────
// Per-model token breakdown for a cron run. Populated when sub-agents use
// different models in a single run. The unique constraint on [cronRunId, model]
// allows upsert semantics.

model AgentCronRunModelBreakdown {
  id                  String       @id @default(cuid())
  cronRunId           String
  model               String
  inputTokens         Int          @default(0)
  outputTokens        Int          @default(0)
  cacheReadTokens     Int          @default(0)
  cacheCreationTokens Int          @default(0)
  costUsd             Float        @default(0)
  cronRun             AgentCronRun @relation(fields: [cronRunId], references: [id], onDelete: Cascade)

  @@unique([cronRunId, model])
}

// ─── Agent Chat Token Usage (Daily, per Model) ───────────────────────────────
// Daily rollup table for Slack/chat session token usage per agent per model.
// Accumulated atomically via INSERT ... ON CONFLICT ... DO UPDATE (no read-modify-write).
// Totals and byAgent aggregations are computed by summing across models.

model AgentChatTokenUsageDailyByModel {
  id                  String   @id @default(cuid())
  agentId             String
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  date                String   // YYYY-MM-DD
  model               String   // e.g. "claude-sonnet-4-5"
  inputTokens         Int      @default(0)
  outputTokens        Int      @default(0)
  cacheReadTokens     Int      @default(0)
  cacheCreationTokens Int      @default(0)
  costUsd             Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([agentId, date, model])
}

