{
  "name": "@shipwright/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "description": "Shipwright admin service — CRUD API + UI for agents, env vars, cron jobs, tokens, tools, and plugins",
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "@prisma/client": "^6.19.2",
    "@sentry/bun": "^10.63.0",
    "@sentry/hono": "^10.63.0",
    "@shipwright/lib": "*",
    "hono": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "bun-types": "^1.3.14",
    "prisma": "^6.19.2",
    "typescript": "*"
  }
}
