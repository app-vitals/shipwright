{
  "name": "@shipwright/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shipwright admin service — CRUD API + UI for agents, env vars, cron jobs, tokens, tools, and plugins",
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "test": "bun test",
    "test:e2e": "bunx playwright test --config=admin/playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "hono": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "bun-types": "^1.3.14",
    "prisma": "^6.19.2",
    "typescript": "*"
  }
}
