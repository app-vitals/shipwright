{
  "$comment": "Canonical design tokens for Shipwright Harness. This file is the single source of truth; brand/BRAND.md mirrors these values for humans, and the shipwright-brand skill reads THIS file when generating artifacts. Hex/literal values only — never env vars, secrets, or paths.",
  "brand": {
    "name": "Shipwright Harness",
    "package": "shipwright",
    "tagline": "The open-source autonomous delivery agent for Claude Code.",
    "subTagline": "A deployable cloud agent and the autonomous coding system that powers it — built on the Shipwright plugin, running on your own codebase.",
    "install": "/plugin install shipwright@app-vitals/shipwright"
  },
  "color": {
    "bg": {
      "base": "#080E1E",
      "raised": "#0F172A",
      "overlay": "#1E293B"
    },
    "border": {
      "subtle": "#1E293B",
      "muted": "#334155",
      "strong": "#475569"
    },
    "brand": {
      "default": "#34C77B",
      "strong": "#2BAE6E",
      "soft": "#0F2D1E",
      "onBrandText": "#080E1E"
    },
    "support": {
      "patriot": "#002244",
      "patriotBright": "#4F8EF7",
      "cyan": "#22D3EE",
      "violet": "#8B5CF6"
    },
    "$supportNote": "Patriot Blue = PMS 289 C / #002244 (deep maritime navy): surfaces, panels, diagram/node backgrounds, gradient anchor. patriotBright #4F8EF7 is the contrast-safe same-family tint for links, in-progress/PR state, and diagram strokes on the dark base.",
    "text": {
      "heading": "#FFFFFF",
      "body": "rgba(255,255,255,0.80)",
      "editorial": "rgba(255,255,255,0.50)",
      "muted": "rgba(255,255,255,0.25)"
    },
    "state": {
      "success": "#34C77B",
      "progress": "#4F8EF7",
      "pending": "#475569",
      "warning": "#F5B544",
      "danger": "#F87171"
    }
  },
  "gradient": {
    "brand": ["#34C77B", "#22D3EE"],
    "support": ["#4F8EF7", "#8B5CF6"],
    "deep": ["#002244", "#080E1E"]
  },
  "glow": {
    "brand": "rgba(52,199,123,0.25)",
    "support": "rgba(79,142,247,0.22)"
  },
  "font": {
    "display": "\"Space Grotesk\", system-ui, sans-serif",
    "body": "\"General Sans\", \"DM Sans\", system-ui, sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, monospace"
  },
  "fontSource": {
    "Space Grotesk": "Google Fonts",
    "General Sans": "Fontshare",
    "JetBrains Mono": "Google Fonts"
  },
  "type": {
    "displayXl": {
      "size": "4.5rem",
      "line": "1.05",
      "weight": 700,
      "tracking": "-0.02em",
      "font": "display"
    },
    "displayL": {
      "size": "3rem",
      "line": "1.08",
      "weight": 700,
      "tracking": "-0.02em",
      "font": "display"
    },
    "h1": {
      "size": "2.25rem",
      "line": "1.15",
      "weight": 700,
      "tracking": "-0.01em",
      "font": "display"
    },
    "h2": {
      "size": "1.75rem",
      "line": "1.2",
      "weight": 600,
      "tracking": "-0.01em",
      "font": "display"
    },
    "h3": {
      "size": "1.375rem",
      "line": "1.25",
      "weight": 600,
      "tracking": "0",
      "font": "display"
    },
    "bodyL": {
      "size": "1.125rem",
      "line": "1.6",
      "weight": 400,
      "tracking": "0",
      "font": "body"
    },
    "body": {
      "size": "1rem",
      "line": "1.6",
      "weight": 400,
      "tracking": "0",
      "font": "body"
    },
    "small": {
      "size": "0.875rem",
      "line": "1.5",
      "weight": 400,
      "tracking": "0",
      "font": "body"
    },
    "label": {
      "size": "0.8125rem",
      "line": "1.4",
      "weight": 500,
      "tracking": "0.08em",
      "font": "mono",
      "transform": "uppercase"
    }
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "pill": "9999px"
  },
  "layout": {
    "maxWidth": "72rem",
    "sectionPaddingY": "6rem",
    "gutter": "1.5rem"
  },
  "links": {
    "discoveryCall": "https://cal.com/team/app-vitals/discovery-call",
    "repo": "https://github.com/app-vitals/shipwright",
    "site": "https://shipwrightharness.com"
  }
}
